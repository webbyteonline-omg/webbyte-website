// This is your Prisma schema file
// Learn more at https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          Role      @default(CLIENT)
  phone         String?
  company       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt @default(now())

  accounts Account[]
  sessions Session[]
  orders   Order[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Order {
  id              String        @id @default(cuid())
  orderNumber     String        @unique
  userId          String?
  customerName    String
  customerEmail   String
  customerPhone   String
  productId       String
  productName     String
  productPrice    Float
  requirements    String?
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(UNPAID)
  paymentMethod   String?
  paymentId       String?
  deliveryDate    DateTime?
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("orders")
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  coverImage  String?
  tags        String?
  published   Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt @default(now())

  @@map("blog_posts")
}

enum Role {
  ADMIN
  CLIENT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

// ── Marketing: Offers & Coupon Codes ──────────────────────────────────────
model Offer {
  id            String    @id @default(cuid())
  title         String
  code          String    @unique
  discountType  String    @default("PERCENTAGE") // PERCENTAGE | FIXED
  discountValue Float
  description   String?
  minOrderValue Float?
  maxUses       Int?
  usedCount     Int       @default(0)
  active        Boolean   @default(true)
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt @default(now())

  @@map("offers")
}

// ── Marketing: Site Banners ───────────────────────────────────────────────
model SiteBanner {
  id         String    @id @default(cuid())
  title      String
  subtitle   String?
  badge      String?
  ctaText    String?
  ctaLink    String?
  gradient   String    @default("from-purple-600 to-indigo-700")
  position   String    @default("homepage") // top-strip | homepage | industries | order
  style      String    @default("strip")    // strip | card | floating
  active     Boolean   @default(true)
  priority   Int       @default(0)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt @default(now())

  @@map("site_banners")
}

// ── Marketing: Product Pricing Config ────────────────────────────────────
model ProductConfig {
  id          String   @id @default(cuid())
  productId   String   @unique
  productName String
  category    String   @default("website") // website | billing | saas
  basePrice   Float
  salePrice   Float?
  active      Boolean  @default(true)
  updatedAt   DateTime @updatedAt @default(now())

  @@map("product_configs")
}
